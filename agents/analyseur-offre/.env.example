# Environment variables for local development
# DO NOT commit sensitive values to git

# Parser-PDF service
PARSER_SERVICE_URL=http://parser-pdf:8001

# Google Cloud Platform
GCP_PROJECT_ID=talentious-project
# europe-west9 (Paris) - Souveraineté des données française/EU (RGPD compliant)
# Gemini 2.5 Flash disponible avec contexte 1M tokens (~750K chars)
GCP_LOCATION=europe-west9

# GCP Authentication (Application Default Credentials)
# In development, credentials are mounted from ~/.config/gcloud/application_default_credentials.json
# In production (Cloud Run), this is handled automatically by the service account
# GOOGLE_APPLICATION_CREDENTIALS=/tmp/gcp_creds.json

# Vertex AI
VERTEX_AI_MODEL=gemini-2.5-flash  # Latest stable, optimized for speed with large context window

# Prompt Management
# Set to "true" to use GCP Secret Manager for prompts (production)
# Set to "false" to use local files in prompts/ directory (development)
USE_SECRET_MANAGER=false

# Logging
LOG_LEVEL=INFO
