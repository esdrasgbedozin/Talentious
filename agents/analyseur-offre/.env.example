# Environment variables for local development
# DO NOT commit sensitive values to git

# Parser-PDF service
PARSER_SERVICE_URL=http://parser-pdf:8001

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=europe-west9

# Vertex AI
VERTEX_AI_MODEL=gemini-1.5-flash-002

# Prompt Management
# Set to "true" to use GCP Secret Manager for prompts (production)
# Set to "false" to use local files in prompts/ directory (development)
USE_SECRET_MANAGER=false

# Logging
LOG_LEVEL=INFO
