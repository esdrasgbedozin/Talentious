# Environment Variables
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=postgresql://talentious:talentious@db:5432/talentious

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GCP (for production)
GCP_PROJECT_ID=talentious-project
GCP_SQL_CONNECTION_NAME=talentious-project:europe-west9:talentious-db-prod
GCP_BUCKET_NAME=talentious-project-cvs

# Application
ENVIRONMENT=development
DEBUG=True
