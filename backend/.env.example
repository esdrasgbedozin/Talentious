# Environment Variables - Talentious Backend
# Copy this file to .env and fill in your actual values for local development

# Database Configuration
# Local format: postgresql+asyncpg://user:password@host:port/database
# Cloud Run format: postgresql+asyncpg://user:password@/database?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://talentious:talentious@db:5432/talentious

# Security & Authentication
# Generate strong key with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days (default)

# Application Settings
ENVIRONMENT=development
DEBUG=True
APP_NAME=Talentious API

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# GCP Configuration (for Cloud Run deployment)
# These values are used in production and loaded from Secret Manager
GCP_PROJECT_ID=talentious-project
CLOUD_SQL_CONNECTION_NAME=talentious-project:europe-west9:talentious-db
GCP_BUCKET_NAME=talentious-project-cvs

# Stripe Configuration (for future payment integration)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Note: In production (Cloud Run), SECRET_KEY and DATABASE_URL 
# are loaded from GCP Secret Manager, not from environment variables.
# See .github/SECRET_MANAGER_SETUP.md for configuration details.

