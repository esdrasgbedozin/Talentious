{
  "hosting": [
    {
      "target": "app",
      "public": "firebase/public",
      "ignore": ["**/.*"],
      "rewrites": [
        {
          "source": "**",
          "run": { "serviceId": "frontend", "region": "europe-west9" }
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "/_next/static/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
    {
      "target": "api",
      "public": "firebase/public",
      "ignore": ["**/.*"],
      "rewrites": [
        {
          "source": "**",
          "run": { "serviceId": "backend", "region": "europe-west9" }
        }
      ]
    }
  ]
}
